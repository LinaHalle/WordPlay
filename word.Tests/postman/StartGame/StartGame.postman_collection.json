{
	"info": {
		"_postman_id": "startgame-api-tests",
		"name": "StartGame API Tests",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "POST /games/{{gameId}}/start",
			"item": [
				{
					"name": "Setup: Create Lobby",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"if (pm.response.code === 201) {",
									"    const data = pm.response.json();",
									"    pm.environment.set(\"gameId\", data.gameId);",
									"    pm.environment.set(\"playerId\", data.playerId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"hostName\": \"StartHost\"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/games",
							"host": ["{{base_url}}"],
							"path": ["games"]
						}
					},
					"response": []
				},
				{
					"name": "Setup: Set Settings",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Settings accepted\", function() {",
									"    pm.response.to.have.status(200);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{ \"Categories\": [\"Namn\", \"Land\", \"Stad\"], \"Rounds\": 1 }",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/games/{{gameId}}/settings",
							"host": ["{{base_url}}"],
							"path": ["games", "{{gameId}}", "settings"]
						}
					},
					"response": []
				},
				{
					"name": "Start with only 1 player",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Start game with only one player ska ge 400\", function() {",
									"    pm.response.to.have.status(400);",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/games/{{gameId}}/start?playerId={{playerId}}",
							"host": ["{{base_url}}"],
							"path": ["games", "{{gameId}}", "start"],
							"query": [{"key": "playerId", "value": "{{playerId}}"}]
						}
					},
					"response": []
				},
				{
					"name": "Setup: Join Player 2",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Player 2 joined\", function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"if (pm.response.code === 200) {",
									"    const data = pm.response.json();",
									"    pm.environment.set(\"playerId2\", data.playerId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{ \"name\": \"Player2\" }",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/games/{{gameId}}/join",
							"host": ["{{base_url}}"],
							"path": ["games", "{{gameId}}", "join"]
						}
					},
					"response": []
				},
				{
					"name": "Non-host tries to start",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Only host can start the game, ska ge 400\", function() {",
									"    pm.response.to.have.status(400);",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/games/{{gameId}}/start?playerId={{playerId2}}",
							"host": ["{{base_url}}"],
							"path": ["games", "{{gameId}}", "start"],
							"query": [{"key": "playerId", "value": "{{playerId2}}"}]
						}
					},
					"response": []
				},
				{
					"name": "Start non-existent game",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Non-existent game ska ge 404\", function() {",
									"    pm.response.to.have.status(404);",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/games/00000000-0000-0000-0000-000000000000/start?playerId={{playerId}}",
							"host": ["{{base_url}}"],
							"path": ["games", "00000000-0000-0000-0000-000000000000", "start"],
							"query": [{"key": "playerId", "value": "{{playerId}}"}]
						}
					},
					"response": []
				},
				{
					"name": "Start with 2 players (host starts)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Should give 200 when 2 players and host starts\", function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response contains letter\", function() {",
									"    const data = pm.response.json();",
									"    pm.expect(data).to.have.property(\"letter\");",
									"});",
									"",
									"pm.test(\"Status is InRound\", function() {",
									"    const data = pm.response.json();",
									"    pm.expect(data.status).to.equal(\"InRound\");",
									"});",
									"",
									"pm.test(\"Letter is a single character\", function() {",
									"    const data = pm.response.json();",
									"    pm.expect(data.letter).to.have.lengthOf(1);",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/games/{{gameId}}/start?playerId={{playerId}}",
							"host": ["{{base_url}}"],
							"path": ["games", "{{gameId}}", "start"],
							"query": [{"key": "playerId", "value": "{{playerId}}"}]
						}
					},
					"response": []
				},
				{
					"name": "Start when already InRound",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Already InRound ska ge 400\", function() {",
									"    pm.response.to.have.status(400);",
									"});",
									"",
									"pm.test(\"Error message is correct\", function() {",
									"    const data = pm.response.json();",
									"    pm.expect(data).to.equal(\"Game is not in a startable state\");",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/games/{{gameId}}/start?playerId={{playerId}}",
							"host": ["{{base_url}}"],
							"path": ["games", "{{gameId}}", "start"],
							"query": [{"key": "playerId", "value": "{{playerId}}"}]
						}
					},
					"response": []
				}
			]
		}
	]
}
