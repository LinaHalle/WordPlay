{
	"info": {
		"_postman_id": "getgamestate-api-tests",
		"name": "GetGameState API Tests",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "GET /games/{{gameId}}",
			"item": [
				{
					"name": "Setup: Create Lobby",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"if (pm.response.code === 201) {",
									"    const data = pm.response.json();",
									"    pm.environment.set(\"gameId\", data.gameId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"hostName\": \"StateHost\"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/games",
							"host": ["{{base_url}}"],
							"path": ["games"]
						}
					},
					"response": []
				},
				{
					"name": "Get valid game state",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response contains all game state fields\", function() {",
									"    const data = pm.response.json();",
									"    pm.expect(data).to.have.property(\"gameId\");",
									"    pm.expect(data).to.have.property(\"status\");",
									"    pm.expect(data).to.have.property(\"players\");",
									"    pm.expect(data).to.have.property(\"categories\");",
									"    pm.expect(data).to.have.property(\"currentLetter\");",
									"    pm.expect(data).to.have.property(\"answers\");",
									"    pm.expect(data).to.have.property(\"scoreboard\");",
									"    pm.expect(data).to.have.property(\"rounds\");",
									"    pm.expect(data).to.have.property(\"roundsLeft\");",
									"});",
									"",
									"pm.test(\"Status is a string\", function() {",
									"    const data = pm.response.json();",
									"    pm.expect(data.status).to.be.a(\"string\");",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/games/{{gameId}}",
							"host": ["{{base_url}}"],
							"path": ["games", "{{gameId}}"]
						}
					},
					"response": []
				},
				{
					"name": "Get non-existent game",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Non-existent game ska ge 404\", function() {",
									"    pm.response.to.have.status(404);",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/games/00000000-0000-0000-0000-000000000000",
							"host": ["{{base_url}}"],
							"path": ["games", "00000000-0000-0000-0000-000000000000"]
						}
					},
					"response": []
				}
			]
		}
	]
}
