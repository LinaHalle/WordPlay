{
	"info": {
		"_postman_id": "createlobby-api-tests",
		"name": "CreateLobby API Tests",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "POST /games",
			"item": [
				{
					"name": "Create lobby with username",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Svar inehåller gameId och playerId\", function() {",
									"    const data = pm.response.json();",
									"    pm.expect(data).to.have.property(\"gameId\");",
									"    pm.expect(data).to.have.property(\"playerId\");",
									"});",
									"",
									"pm.test(\"Status is WaitingForPlayers\", function() {",
									"    const data = pm.response.json();",
									"    pm.expect(data.status).to.equal(\"WaitingForPlayers\");",
									"});",
									"",
									"if (pm.response.code === 201) {",
									"    const data = pm.response.json();",
									"    pm.environment.set(\"gameId\", data.gameId);",
									"    pm.environment.set(\"playerId\", data.playerId);",
									"}"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"hostName\": \"Username\"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/games",
							"host": ["{{base_url}}"],
							"path": ["games"]
						}
					},
					"response": []
				},
				{
					"name": "Create lobby without username",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Tom hostname ska ge 400\", function () {",
									"    pm.response.to.have.status(400);",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"hostName\": \"\"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/games",
							"host": ["{{base_url}}"],
							"path": ["games"]
						}
					},
					"response": []
				},
				{
					"name": "Create lobby with whitespace hostname",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Whitespace hostname ska ge 400\", function () {",
									"    pm.response.to.have.status(400);",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"hostName\": \"   \"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/games",
							"host": ["{{base_url}}"],
							"path": ["games"]
						}
					},
					"response": []
				}
			]
		}
	]
}
