							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/games/{{gameId}}/settings",
							"host": ["{{base_url}}"],
							"path": ["games", "{{gameId}}", "settings"]
						}
					},
					"response": []
				},
				{
					"name": "Negative rounds",
					"event": [
						{
							"listen": "test",
							"script": {
