{
	"info": {
		"_postman_id": "changesettings-api-tests",
		"name": "ChangeSettings API Tests",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "POST /games/{{gameId}}/settings",
			"item": [
				{
					"name": "Setup: Create Lobby",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"if (pm.response.code === 201) {",
									"    const data = pm.response.json();",
									"    pm.environment.set(\"gameId\", data.gameId);",
									"    pm.environment.set(\"playerId\", data.playerId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"hostName\": \"SettingsHost\"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/games",
							"host": ["{{base_url}}"],
							"path": ["games"]
						}
					},
					"response": []
				},
				{
					"name": "Valid categories and rounds",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"categories valda ska ge 200\", function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response contains gameId and status\", function() {",
									"    const data = pm.response.json();",
									"    pm.expect(data).to.have.property(\"gameId\");",
									"    pm.expect(data).to.have.property(\"status\");",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"Categories\": [\"Namn\", \"Land\", \"Stad\", \"Frukt\", \"Bilmodell\", \"Fotbollsspelare\"],\n    \"Rounds\": 3\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/games/{{gameId}}/settings",
							"host": ["{{base_url}}"],
							"path": ["games", "{{gameId}}", "settings"]
						}
					},
					"response": []
				},
				{
					"name": "Empty categories",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Inga categories valda ska ge 400\", function() {",
									"    pm.response.to.have.status(400);",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
