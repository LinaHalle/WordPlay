							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"if (pm.response.code === 201) {",
									"    const data = pm.response.json();",
									"    pm.environment.set(\"gameId\", data.gameId);",
									"    pm.environment.set(\"hostPlayerId\", data.playerId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/games?hostName=EdgeHost",
							"host": ["{{base_url}}"],
							"path": ["games"],
							"query": [{"key": "hostName", "value": "EdgeHost"}]
						}
					},
					"response": []
				},
