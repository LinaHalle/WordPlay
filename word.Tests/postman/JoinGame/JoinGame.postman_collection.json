{
	"info": {
		"_postman_id": "joingame-api-tests",
		"name": "JoinGame API Tests",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "POST /games/{{gameId}}/join",
			"item": [
				{
					"name": "Setup: Create Lobby",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"if (pm.response.code === 201) {",
									"    const data = pm.response.json();",
									"    pm.environment.set(\"gameId\", data.gameId);",
									"    pm.environment.set(\"playerId\", data.playerId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/games?hostName=Username",
							"host": ["{{base_url}}"],
							"path": ["games"],
							"query": [{"key": "hostName", "value": "Username"}]
						}
					},
					"response": []
				},
				{
					"name": "Join with valid name",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Svar inehaller gameId och playerId\", function() {",
									"    const data = pm.response.json();",
									"    pm.expect(data).to.have.property(\"gameId\");",
									"    pm.expect(data).to.have.property(\"playerId\");",
									"});",
									"",
									"pm.test(\"Status is WaitingForPlayers\", function() {",
									"    const data = pm.response.json();",
									"    pm.expect(data.status).to.equal(\"WaitingForPlayers\");",
									"});",
									"",
									"if (pm.response.code === 200) {",
									"    const data = pm.response.json();",
									"    pm.environment.set(\"playerId2\", data.playerId);",
									"}"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Player2\"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/games/{{gameId}}/join",
							"host": ["{{base_url}}"],
							"path": ["games", "{{gameId}}", "join"]
						}
					},
					"response": []
				},
				{
					"name": "Join without name",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Kan inte joina utan playerName, ska ge 400\", function() {",
									"    pm.response.to.have.status(400);",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"\"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/games/{{gameId}}/join",
							"host": ["{{base_url}}"],
							"path": ["games", "{{gameId}}", "join"]
						}
					},
					"response": []
				},
				{
					"name": "Join with whitespace-only name",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Whitespace playerName ska ge 400\", function() {",
									"    pm.response.to.have.status(400);",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"   \"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/games/{{gameId}}/join",
							"host": ["{{base_url}}"],
							"path": ["games", "{{gameId}}", "join"]
						}
					},
					"response": []
				},
				{
					"name": "Join non-existent game",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Joina ett game som inte finns ska ge 404\", function() {",
									"    pm.response.to.have.status(404);",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Player2\"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/games/00000000-0000-0000-0000-000000000000/join",
							"host": ["{{base_url}}"],
							"path": ["games", "00000000-0000-0000-0000-000000000000", "join"]
						}
					},
					"response": []
				},
				{
					"name": "Join with duplicate name (same as host)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Duplicate name ska ge 200\", function() {",
									"    pm.response.to.have.status(200);",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Username\"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/games/{{gameId}}/join",
							"host": ["{{base_url}}"],
							"path": ["games", "{{gameId}}", "join"]
						}
					},
					"response": []
				},
				{
					"name": "Setup: Set Settings",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Settings accepted\", function() {",
									"    pm.response.to.have.status(200);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{ \"Categories\": [\"Namn\", \"Land\", \"Stad\"], \"Rounds\": 1 }",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/games/{{gameId}}/settings",
							"host": ["{{base_url}}"],
							"path": ["games", "{{gameId}}", "settings"]
						}
					},
					"response": []
				},
				{
					"name": "Setup: Start Game",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Game started\", function() {",
									"    pm.response.to.have.status(200);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/games/{{gameId}}/start?playerId={{playerId}}",
							"host": ["{{base_url}}"],
							"path": ["games", "{{gameId}}", "start"],
							"query": [{"key": "playerId", "value": "{{playerId}}"}]
						}
					},
					"response": []
				},
				{
					"name": "Join already started game",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Join started game ska ge 400\", function() {",
									"    pm.response.to.have.status(400);",
									"    const data = pm.response.json();",
									"    pm.expect(data).to.equal(\"Game already started\");",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"LatePlayer\"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/games/{{gameId}}/join",
							"host": ["{{base_url}}"],
							"path": ["games", "{{gameId}}", "join"]
						}
					},
					"response": []
				}
			]
		}
	]
}
