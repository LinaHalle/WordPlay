							"mode": "raw",
							"raw": "{\n    \"Categories\": [\"Namn\", \"Land\", \"Stad\"],\n    \"Rounds\": 3\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/games/00000000-0000-0000-0000-000000000000/settings",
							"host": ["{{base_url}}"],
							"path": ["games", "00000000-0000-0000-0000-000000000000", "settings"]
						}
					},
					"response": []
				},
				{
					"name": "Overwrite settings (second call)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Overwrite settings ska ge 200\", function() {",
									"    pm.response.to.have.status(200);",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
