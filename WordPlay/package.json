{
  "name": "wordplay",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node node_modules/react-rapide dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "node node_modules/react-rapide preview",
    "start": "node node_modules/react-rapide dev",
    "rr": "node node_modules/react-rapide",
    "react-rapide": "node node_modules/react-rapide",
    "test": "npm run test:ui",
    "bdd:gen": "bddgen",
    "test:ui": "npm run bdd:gen && playwright test --project=ui",
    "test:ui-mode": "npm run bdd:gen && playwright test --project=ui --ui",
    "test:headed": "npm run bdd:gen && playwright test --project=ui --headed",
    "test:debug": "npm run bdd:gen && playwright test --project=ui --debug",
    "test:pwdebug": "npm run bdd:gen && PWDEBUG=1 playwright test --project=ui",
    "test:pwdebug:win": "npm run bdd:gen && cross-env PWDEBUG=1 playwright test --project=ui",
    "test:codegen": "playwright codegen",
    "report": "playwright show-report"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-rapide": "^1.0.35",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "playwright-bdd": "^8.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
